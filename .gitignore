# =============================================================
# VisionStream .gitignore
# =============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Docker
.docker/

# Locust load test results
locust_results/
*.csv
locust_report.html

# Jupyter Notebooks
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Data files (Geolife dataset — too large for version control)
data/
*.plt

# Logs
*.log
logs/
