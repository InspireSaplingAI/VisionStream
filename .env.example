# =============================================================
# VisionStream Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# Application
APP_NAME=VisionStream
DEBUG=false

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://visionstream:changeme@localhost:5432/visionstream

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# API authentication key (used for device → API requests)
# Change this before any production deployment
API_KEY=changeme-dev-key-replace-in-production
